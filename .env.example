# Подключение к PostgreSQL (Timeweb Cloud)
# Формат: postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require
DATABASE_URL="postgresql://user:password@localhost:5432/stal_dveri?schema=public"

# Секрет для NextAuth (сгенерировать: openssl rand -base64 32)
AUTH_SECRET="change-me-32-chars-min-random-string"

# Базовый URL приложения (для клиентских ссылок /order/{token})
# В проде указать публичный адрес, напр. https://armora.timeweb.cloud
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Для NextAuth v5 на проде должен совпадать с NEXT_PUBLIC_APP_URL
AUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST="true"

# Node окружение
NODE_ENV="production"

# Контакты компании, отображаются на клиентской странице
NEXT_PUBLIC_COMPANY_NAME="Armora"
NEXT_PUBLIC_COMPANY_PHONE="+7 (495) 123-45-67"
NEXT_PUBLIC_COMPANY_PHONE_DIGITS="74951234567"
