// Prisma schema для «СтальДверь»
// Таблицы: users, orders, order_comments, company_settings, sessions (NextAuth)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =====================================================================
// Сотрудники компании (login = email)
// =====================================================================
enum Role {
  director
  manager
  surveyor
  installer
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String   // bcrypt-хеш
  fullName  String   @map("full_name")
  phone     String?
  role      Role
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  // обратные связи
  ordersAsSurveyor  Order[]        @relation("SurveyorOrders")
  ordersAsInstaller Order[]        @relation("InstallerOrders")
  ordersCreated     Order[]        @relation("CreatedByOrders")
  comments          OrderComment[]
  sessions          Session[]
  pushSubscriptions PushSubscription[]
  assignedLeads     Lead[]         @relation("AssignedLeads")

  @@map("users")
}

// =====================================================================
// Заказы
// =====================================================================
enum Stage {
  new                // 1. Новая
  survey_scheduled   // 2. Замер назначен
  survey_done        // 3. Замер сделан, аванс получен
  production         // 4. В производстве
  ready_to_install   // 5. Готова к установке
  installed          // 6. Установлена
  pending_closure    // 7. Ожидает подтверждения закрытия (директором)
  closed             // 8. Закрыта (только директор)
}

model Order {
  id     String @id @default(uuid())
  number Int    @unique @default(autoincrement()) // человекочитаемый № 142

  // Публичная ссылка для клиента
  publicToken     String    @unique @map("public_token")
  tokenExpiresAt  DateTime? @map("token_expires_at") // null = бессрочно (до закрытия)

  // Клиент
  clientName         String @map("client_name")
  clientPhone        String @map("client_phone")
  // Только цифры из телефона — для быстрого поиска по любому формату ввода.
  // Заполняется автоматически на create/update в actions.ts.
  clientPhoneDigits  String @default("") @map("client_phone_digits")
  clientAddress      String @map("client_address")

  // Дверь
  doorComment String  @default("") @map("door_comment")
  widthMm     Int?    @map("width_mm")
  heightMm    Int?    @map("height_mm")

  // Деньги
  totalAmount  Decimal @default(0) @map("total_amount")  @db.Decimal(10, 2)  // цена по договору
  prepayment   Decimal @default(0) @map("prepayment")    @db.Decimal(10, 2)  // аванс получен
  finalPayment Decimal @default(0) @map("final_payment") @db.Decimal(10, 2)  // остаток получен (факт)
  costAmount   Decimal @default(0) @map("cost_amount")   @db.Decimal(10, 2)  // себестоимость (внутреннее)

  // Статус
  stage Stage @default(new)

  // Назначения
  surveyorId  String?   @map("surveyor_id")
  installerId String?   @map("installer_id")
  surveyAt    DateTime? @map("survey_at")
  installAt   DateTime? @map("install_at")

  // Аудит
  createdById String   @map("created_by")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  surveyor  User?          @relation("SurveyorOrders",  fields: [surveyorId],  references: [id])
  installer User?          @relation("InstallerOrders", fields: [installerId], references: [id])
  createdBy User           @relation("CreatedByOrders", fields: [createdById], references: [id])
  comments  OrderComment[]
  fromLead  Lead?          @relation("ConvertedFromLead")

  // Индексы под типичные запросы
  @@index([stage])
  @@index([surveyorId])
  @@index([installerId])
  @@index([surveyAt])
  @@index([installAt])
  // Composite-индексы под фильтры расписания
  @@index([stage, surveyAt])
  @@index([stage, installAt])
  // Поиск по нормализованному телефону
  @@index([clientPhoneDigits])
  @@map("orders")
}

// =====================================================================
// Комментарии замерщика/установщика
// =====================================================================
model OrderComment {
  id        String   @id @default(uuid())
  orderId   String   @map("order_id")
  authorId  String   @map("author_id")
  text      String
  createdAt DateTime @default(now()) @map("created_at")

  order  Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  author User  @relation(fields: [authorId], references: [id])

  @@index([orderId])
  @@map("order_comments")
}

// =====================================================================
// Настройки компании (всегда одна строка с id=1)
// =====================================================================
model CompanySettings {
  id           Int    @id @default(1)
  companyName  String @map("company_name")
  companyPhone String @map("company_phone")

  @@map("company_settings")
}

// =====================================================================
// Аудит попыток входа + лимит брутфорса
// =====================================================================
model LoginAttempt {
  id        String   @id @default(uuid())
  login     String                            // нормализованный логин (lowercase, как введено)
  ip        String?
  userAgent String?  @map("user_agent")
  ok        Boolean                           // true = успех, false = провал
  reason    String?                           // ok | bad_password | not_found | inactive | blocked
  createdAt DateTime @default(now()) @map("created_at")

  @@index([login, createdAt])
  @@index([ip, createdAt])
  @@map("login_attempts")
}

// =====================================================================
// Push-уведомления (Web Push API)
// =====================================================================
// Каждый user может иметь несколько подписок (телефон + ноутбук, например).
// При каждой подписке браузер выдаёт уникальный endpoint — он и ключ.
model PushSubscription {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  endpoint  String   @unique
  p256dh    String                              // public key из браузера (base64url)
  auth      String                              // auth secret из браузера (base64url)
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("push_subscriptions")
}

// =====================================================================
// Сессии NextAuth
// =====================================================================
model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

// =====================================================================
// Заявки с сайта (calculator → lead → конверсия в Order)
// =====================================================================
// Lead — это входящая заявка с публичной формы. Хранится отдельно от
// Order, чтобы:
//   1) не мешать спам/мусор реальным заказам (статусы spam, rejected);
//   2) сохранить весь сырой payload калькулятора (JSON) — даже если
//      форма поменяется, история останется;
//   3) видеть конверсию: сколько лидов → сколько закрытых заказов.
// При нажатии «Создать заказ» Lead.stage становится converted и
// проставляется convertedOrderId.

enum LeadStage {
  new          // 1. Только что пришла, никто не смотрел
  contacted    // 2. Менеджер связался
  scheduled    // 3. Договорились на замер
  converted    // 4. Создан заказ → convertedOrderId
  rejected     // 5. Отказ клиента
  spam         // 6. Помечена как мусор/бот
}

model Lead {
  id     String @id @default(uuid())
  number Int    @unique @default(autoincrement())

  // Контакты клиента (минимально обязательно: имя+телефон)
  clientName        String  @map("client_name")
  clientPhone       String  @map("client_phone")
  clientPhoneDigits String  @default("") @map("client_phone_digits")
  clientAddress     String? @map("client_address")

  // Опциональные параметры двери (для предзаполнения Order)
  widthMm  Int? @map("width_mm")
  heightMm Int? @map("height_mm")

  // Свободный комментарий клиента
  comment String @default("")

  // Сырой payload с калькулятора — любые доп. поля (цвет, замок, отделка...).
  // Используем JSON, чтобы схема не ломалась при изменении формы.
  payload Json @default("{}")

  // Прикинутая клиентом цена в калькуляторе (для справки)
  estimatedPrice Decimal? @map("estimated_price") @db.Decimal(10, 2)

  // Источник: 'calc' (внутренний калькулятор), 'landing', 'phone' и т.п.
  source String @default("calc")

  // Статус воронки
  stage LeadStage @default(new)

  // Назначение (опционально — кто из менеджеров ведёт)
  assignedToId String? @map("assigned_to_id")
  assignedTo   User?   @relation("AssignedLeads", fields: [assignedToId], references: [id])

  // Конверсия в заказ
  convertedOrderId String? @unique @map("converted_order_id")
  convertedOrder   Order?  @relation("ConvertedFromLead", fields: [convertedOrderId], references: [id])

  // Метаданные/аналитика
  ip           String?
  userAgent    String? @map("user_agent")
  utmSource    String? @map("utm_source")
  utmMedium    String? @map("utm_medium")
  utmCampaign  String? @map("utm_campaign")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([stage])
  @@index([clientPhoneDigits])
  @@index([createdAt])
  @@index([assignedToId])
  @@map("leads")
}
